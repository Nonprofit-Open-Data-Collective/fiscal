\itemize{
\item \code{F9_08_REV_TOT_TOT}: Total revenue (\code{revenue})
\item \code{F9_09_EXP_TOT_TOT}: Total functional expenses (\code{expenses})
\item \code{F9_09_EXP_DEPREC_TOT}: Depreciation and amortization (\code{depreciation})
}
}
